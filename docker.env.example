# ============================================
# Variables de entorno para Docker
# ============================================
# Copia este archivo como .env y rellena los valores.
#
# Uso:
#   cp docker.env.example .env
#   docker compose up --build
#
# AVISO: los defaults de infra abajo son SOLO para desarrollo local.
# No uses estos secretos en producción. Preferible: docker-compose.dev.yml
# con puertos de DB no expuestos al host.

# API Keys
FINNHUB_API_KEY=tu_finnhub_api_key
FMP_API_KEY=tu_fmp_api_key
GEMINI_API_KEY=tu_gemini_api_key
FRED_API_KEY=
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=
SEC_USER_AGENT=CavaAI/0.1 contact@example.com
QUARTR_API_KEY=
OPENROUTER_API_KEY=

# Auth
BETTER_AUTH_SECRET=tu_secret_aleatorio_muy_largo

# Infra secrets (required for compose — change in any shared/prod environment)
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=example
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=cavaai_research
MINIO_ROOT_USER=portfolio
MINIO_ROOT_PASSWORD=portfoliosecret

# Research OS / observability
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=cavaai-local-langfuse-salt
LANGFUSE_INIT_USER_PASSWORD=
